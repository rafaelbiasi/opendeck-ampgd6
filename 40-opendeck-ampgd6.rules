# udev rules for FIFINE Ampligame D6 and newer D6 (Pro?)
SUBSYSTEM=="usb", ATTRS{idVendor}=="3142", ATTRS{idProduct}=="0007", MODE="0660", TAG+="uaccess"
KERNEL=="hidraw*", SUBSYSTEM=="hidraw", ATTRS{idVendor}=="3142", ATTRS{idProduct}=="0007", MODE="0660", TAG+="uaccess"

SUBSYSTEM=="usb", ATTRS{idVendor}=="3142", ATTRS{idProduct}=="0060", MODE="0660", TAG+="uaccess"
KERNEL=="hidraw*", SUBSYSTEM=="hidraw", ATTRS{idVendor}=="3142", ATTRS{idProduct}=="0060", MODE="0660", TAG+="uaccess"
